(MetaModel domain=test.model2 name=CarCompany
	(Group Entity
		(+att name=name datatype=#LMCore@string [1..1]))

	(Enum Brand Renault,Peugeot)

	(Definition Car
		(includes group=@Entity)
		(-att name=brand datatype=@Brand [1..1] defaultValue="Peugeot")
		(+contains name=passengers concept=@Person [0..*])
	)

	(Definition CarParc
		(+contains cars [0..*] @Car)
	)

	(Definition Person
	    (includes group=@Entity)
	    (+refers car [0..1] @Car))

	(Definition CarCompany
	    (includes group=@Entity)
	    (+contains ceo @Entity [1..1])
	    (+contains name=parcs @Car [0..*]))

	(Definition GenericContainer
		(Generic Y)
		(Generic T
			(extension boundType=Extends type=@JavaList
				(parameters wildcard=true wildcardBoundType=Extends type=@JavaSupplier
				    (parameters wildcard=true wildcardBoundType=Super type=../../../../generics.0))))
		(-att list [0..1] @JavaList
			(parameters wildcard=true wildcardBoundType=Extends type=@JavaSupplier
				(parameters wildcard=true wildcardBoundType=Super type=../../../generics.0))))

	(JavaWrapper name=JavaObject qualifiedClassName=java.lang.String)
	(JavaWrapper name=JavaList qualifiedClassName=java.util.List)
	(JavaWrapper name=JavaSupplier qualifiedClassName=java.util.function.Supplier)
)
