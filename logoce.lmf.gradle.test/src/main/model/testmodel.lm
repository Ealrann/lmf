(MetaModel domain=org.logoce.lmf.model.lang name=LMCore

	(Group LMObject)

	(Group Named
		(includes group=@LMObject)
		(-att name=name datatype=@string mandatory))

	(Group Type
		(includes group=@Named)
		(generics name=T))

	(Group Model
		(includes group=@Named)
		(-att name=domain datatype=@string [1..1])
		(-att name=imports datatype=@string [0..*]))

	(Definition MetaModel
		(includes group=@Model)
		(-contains groups [0..*] (reference group=@Group))
		(-contains enums [0..*] (reference group=@Enum))
		(-contains units [0..*] (reference group=@Unit))
		(-contains aliases [0..*] (reference group=@Alias))
		(-contains javaWrappers [0..*] (reference @JavaWrapper))
		(-att lPackage /javaWrappers.1 [1..1]))

	(Definition Group
		(includes group=@Type parameters=../generics.0)
		(includes group=@Concept parameters=../generics.0)
		(Generic T extends @LMObject)
		(-att concrete datatype=@boolean)
		(-contains includes [0..*] (reference group=@Reference))
		(-contains features [0..*] (reference group=@Feature))
		(-contains generics [0..*] (reference group=@Generic)))

	(Group Feature
		(includes group=@Named)
		(Generic UnaryType)
		(Generic EffectiveType)
		(-att name=immutable datatype=@boolean)
		(-att name=many datatype=@boolean)
		(-att name=mandatory datatype=@boolean)
		(-att name=rawFeature datatype=/javaWrappers.0 parameters=../generics.0,../generics.1))

	(Definition Attribute
		(includes group=@Feature parameters=../generics.0,../generics.1)
		(Generic UnaryType)
		(Generic EffectiveType)
		(-refers datatype [1..1] (reference @Datatype parameters=../../generics.0))
		(-att name=defaultValue /units.7)
		(-refers parameters [0..*] (reference group=@Generic)))

	(Definition Relation
		(includes group=@Feature parameters=../generics.0,../generics.1)
		(Generic UnaryType boundType=Extends type=@LMObject)
		(Generic EffectiveType)
		(-contains reference [1..1] (reference group=@Reference parameters=../../generics.0))
		(-att lazy datatype=/units.2)
		(-att contains datatype=/units.2))

	(Group Datatype
		(includes group=@Type parameters=../generics.0)
		(Generic T))
	(Definition Alias
		(includes group=@Named)
		(-att value datatype=@string [1..1]))
	(Definition Enum
		(includes group=@Datatype parameters=../generics.0)
		(Generic T)
		(-att literals datatype=@string [0..*]))
	(Definition Unit
		(includes group=@Datatype parameters=../generics.0)
		(Generic T)
		(-att matcher /units.0 [0..1])
		(-att name=defaultValue datatype=@string [0..1])
		(-att primitive /enums.1 [0..1] defaultValue=String)
		(-att extractor /units.1 [0..1]))

	(Definition Generic
		(includes group=@Concept parameters=../generics.0)
		(Generic T boundType=extends type=@LMObject)
		(-refers type [0..1] (reference group=@Type parameters=../../generics.0))
		(-att boundType datatype=/enums.0))

	(Definition Reference
		(includes @LMObject)
		(Generic name=T boundType=Extends type=@LMObject)
		(-refers group lazy [1..1] (reference group=@Concept parameters=../../generics.0))
		(-refers parameters lazy [0..*] (reference group=@Concept)))

	(Group Concept
		(includes @Named)
		(Generic name=T))

	(Definition JavaWrapper
		(Generic name=T)
		(includes group=@Datatype parameters=../generics.0)
		(-att name=domain /units.7 mandatory))

	(Unit name=matcher matcher="rgx_match:<(.+?)>")
	(Unit name=extractor matcher="rgx_match:<(.+?)>")
	(Enum BoundType extends,super)

	(Enum name=Primitive boolean,int,long,float,double,string)
	(Unit name=boolean matcher="rgx_match:<(true|false)>" defaultValue=false primitive=boolean )
	(Unit name=int matcher="rgx_match:<[0-9]+>" defaultValue=0 primitive=int     )
	(Unit name=long matcher="rgx_match:<[0-9]+[Ll]>" defaultValue=0L primitive=long    )
	(Unit name=float matcher="rgx_match:<[0-9.]+[Ff]>" defaultValue=0f primitive=float   )
	(Unit name=double matcher="rgx_match:<[0-9.]+>" defaultValue=0. primitive=double  )
	(Unit name=string)

	(Alias Definition value="Group concrete")
	(Alias +contains value="Relation contains immutable=false")
	(Alias -contains value="Relation contains immutable")
	(Alias +refers value="Relation contains=false immutable=false")
	(Alias -refers value="Relation contains=false immutable")
	(Alias +att value="Attribute immutable=false")
	(Alias -att value="Attribute immutable")
	(Alias [0..1] value="mandatory=false many=false")
	(Alias [1..1] value="mandatory many=false")
	(Alias [0..*] value="mandatory=false many")
	(Alias [1..*] value="mandatory many")

	(JavaWrapper name=RawFeature domain=org.logoce.lmf.model.api.feature)
	(JavaWrapper name=IModelPackage domain=org.logoce.lmf.model.api.model)
)
